{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Warmlab",
  "author": "melatonia",
  "themes": [
    {
      "name": "Warmlab Light",
      "appearance": "light",
      "style": {
        "background": "#F5F0E8",
        "elevated_surface.background": "#EDE7DB",
        "surface.background": "#F5F0E8",
        "panel.background": "#EDE7DB",
        "status_bar.background": "#F5F0E8",
        "title_bar.background": "#F5F0E8",
        "toolbar.background": "#F5F0E8",
        "tab_bar.background": "#EDE7DB",
        "tab.inactive_background": "#EDE7DB",
        "tab.active_background": "#F5F0E8",
        "editor.background": "#F5F0E8",
        "editor.gutter.background": "#F5F0E8",
        "editor.line_number": "#6E6860",
        "editor.active_line_number": "#28241E",
        "editor.active_line.background": "#EDE7DB",
        "editor.selection.background": "#E2DDD4",
        "editor.foreground": "#28241E",
        "text": "#28241E",
        "text.muted": "#5A5248",
        "text.accent": "#C4601A",
        "icon": "#5A5248",
        "border": "#D4CEC4",
        "border.variant": "#C2BCB2",
        "border.focused": "#C4601A",
        "element.background": "#EDE7DB",
        "element.hover": "#E2DDD4",
        "element.active": "#D4CEC4",
        "element.selected": "#E2DDD4",

        "syntax": {
          "comment": { "color": "#6E6860", "font_style": "italic" },
          "string": { "color": "#4E8C5A" },
          "keyword": { "color": "#8A4418", "font_weight": 700 },
          "function": { "color": "#3A7CA8" },
          "type": { "color": "#3A7CA8" },
          "number": { "color": "#8A6A3A" },
          "property": { "color": "#28241E" },
          "punctuation": { "color": "#5A5248" },
          "operator": { "color": "#8A4418" },
          "variable": { "color": "#28241E" },
          "constant": { "color": "#8A6A3A" },
          "boolean": { "color": "#8A6A3A" },
          "tag": { "color": "#8A4418" }
        },

        "players": [
          {
            "cursor": "#C4601A",
            "background": "#F5D9C8",
            "selection": "#F5D9C8"
          }
        ],

        "terminal.background": "#EDE7DB",
        "terminal.foreground": "#28241E",
        "terminal.ansi.black": "#28241E",
        "terminal.ansi.red": "#A83030",
        "terminal.ansi.green": "#3A7048",
        "terminal.ansi.yellow": "#8A6A3A",
        "terminal.ansi.blue": "#3A7CA8",
        "terminal.ansi.magenta": "#7A4A7A",
        "terminal.ansi.cyan": "#3A7878",
        "terminal.ansi.white": "#C2BCB2"
      }
    },
    {
      "name": "Warmlab Dark",
      "appearance": "dark",
      "style": {
        "background": "#16130F",
        "elevated_surface.background": "#1E1B16",
        "surface.background": "#16130F",
        "panel.background": "#1E1B16",
        "status_bar.background": "#16130F",
        "title_bar.background": "#16130F",
        "toolbar.background": "#16130F",
        "tab_bar.background": "#1E1B16",
        "tab.inactive_background": "#1E1B16",
        "tab.active_background": "#16130F",
        "editor.background": "#16130F",
        "editor.gutter.background": "#16130F",
        "editor.line_number": "#706A62",
        "editor.active_line_number": "#F0EBE2",
        "editor.active_line.background": "#1E1B16",
        "editor.selection.background": "#26231D",
        "editor.foreground": "#F0EBE2",
        "text": "#F0EBE2",
        "text.muted": "#B8B2A8",
        "text.accent": "#E8844A",
        "icon": "#B8B2A8",
        "border": "#2E2A24",
        "border.focused": "#E8844A",
        "element.background": "#1E1B16",
        "element.hover": "#26231D",
        "element.active": "#2E2A24",
        "element.selected": "#26231D",

        "syntax": {
          "comment": { "color": "#706A62", "font_style": "italic" },
          "string": { "color": "#7EC48A" },
          "keyword": { "color": "#E8844A", "font_weight": 700 },
          "function": { "color": "#78B4D4" },
          "type": { "color": "#78B4D4" },
          "number": { "color": "#D4A870" },
          "property": { "color": "#F0EBE2" },
          "punctuation": { "color": "#B8B2A8" },
          "operator": { "color": "#E8844A" },
          "variable": { "color": "#F0EBE2" },
          "constant": { "color": "#D4A870" },
          "boolean": { "color": "#D4A870" },
          "tag": { "color": "#E8844A" }
        },

        "players": [
          {
            "cursor": "#E8844A",
            "background": "#3A1E0A",
            "selection": "#3A1E0A"
          }
        ],

        "terminal.background": "#1E1B16",
        "terminal.foreground": "#F0EBE2",
        "terminal.ansi.black": "#26231D",
        "terminal.ansi.red": "#D46060",
        "terminal.ansi.green": "#7EC48A",
        "terminal.ansi.yellow": "#D4A870",
        "terminal.ansi.blue": "#78B4D4",
        "terminal.ansi.magenta": "#C088C0",
        "terminal.ansi.cyan": "#70B0B0",
        "terminal.ansi.white": "#B8B2A8"
      }
    }
  ]
}
